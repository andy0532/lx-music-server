{
  "name": "lx-music-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler types && wrangler dev",
    "deploy": "wrangler types && wrangler deploy",
    "typecheck": "wrangler types && tsc --noEmit",
    "lint": "biome ci src package.json pnpm-lock.yaml biome.json .github/workflows/*.yml",
    "format:check": "biome ci --linter-enabled=false src package.json pnpm-lock.yaml biome.json .github/workflows/*.yml",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "aes-js": "^3.1.2",
    "hono": "^4.12.26",
    "message2call": "^0.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.102.0"
  },
  "packageManager": "pnpm@11.7.0"
}
